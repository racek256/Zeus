{
  // AthenaAI Phase 2.1 - OpenCode configuration
  // Schema reference: https://opencode.ai/config.json
  "$schema": "https://opencode.ai/config.json",

  // Centralized model identifier - all agents use Kimi K2.6
  "model": "kimi-k2.6",

  // Agent definitions for the Czech grid operator
  "agent": {
    "coordinator": {
      "mode": "primary",
      "description": "ČEPS-level national coordinator with authority over all regional agents",
      "model": "kimi-k2.6",
      "prompt": "You are the AthenaAI national coordinator.\n1. Treat simulator physics as the source of truth.\n2. Use deterministic tools (AC load flow, OPF, N-1) for current state validation — they calculate ground truth.\n3. Use MCP forecast tools (forecast_load, forecast_wind, forecast_solar via athenaai-forecast) for forward-looking decisions — they provide probabilistic predictions with uncertainty bounds.\n4. When forecast uncertainty is high (wide prediction intervals), prefer conservative dispatch — hold more reserve, derate interconnects.\n5. Check N-1 security before operational recommendations.\n6. Simulate proposed actions before committing them.\n7. Monitor grid resilience: use black_start_capability for restoration readiness, voltage_stability_margin for collapse proximity, synchrophasor_monitor for islanding risk.\n8. Track environmental impact: use carbon_intensity_calculation for emissions, weather_impact_assessment for meteorological risks, renewable_curtailment_analysis for wasted clean energy.\n9. Manage flexibility and congestion: use demand_response_potential for load shifting, transmission_congestion_monitor for branch overloads.\n10. Consult Oracle only for diagnostics, anomaly review, and forecast quality assessment.\n11. Use simulated time only.",
      "mcp_servers": ["athenaai-forecast"],
      "tools": [
        "ac_load_flow",
        "optimal_power_flow",
        "n1_contingency_scan",
        "frequency_response",
        "short_circuit",
        "state_estimation",
        "ramp_event_detector",
        "day_ahead_schedule_optimization",
        "merit_order_dispatch",
        "redispatch_cost_calculation",
        "balancing_group_check",
        "interconnect_schedule",
        "reserve_adequacy_check",
        "imbalance_pricing",
        "temperature_to_demand",
        "ev_flexible_load_model",
        "carbon_intensity_calculation",
        "renewable_curtailment_analysis",
        "transmission_congestion_monitor",
        "voltage_stability_margin",
        "demand_response_potential",
        "black_start_capability",
        "synchrophasor_monitor",
        "weather_impact_assessment",
        "load_forecast_15min",
        "wind_nowcast",
        "solar_nowcast",
        "forecast_load",
        "forecast_wind",
        "forecast_solar"
      ]
    },
    "bohemia-west": {
      "mode": "subagent",
      "description": "Generation-heavy region: Temelín/Dukovany nuclear, Prunéřov brown coal",
      "model": "kimi-k2.6",
      "prompt": "You are the Bohemia West regional grid agent.\n1. Monitor regional telemetry for Bohemia West.\n2. Publish observations through the typed peer bus.\n3. Recommend generation support only as advisory input.\n4. Never bypass deterministic physics tools.\n5. Request forecast data from the coordinator via typed negotiation — do NOT call MCP forecast tools directly.\n6. Escalate reliability risks to the national coordinator."
    },
    "bohemia-east": {
      "mode": "subagent",
      "description": "Prague load centre: high demand density, limited local generation",
      "model": "kimi-k2.6",
      "prompt": "You are the Bohemia East regional grid agent.\n1. Monitor Prague load-center reliability.\n2. Identify voltage, overload, and load-supply risks.\n3. Share recommendations through typed peer-bus negotiation only.\n4. Do not issue binding dispatch actions.\n5. Request forecast data from coordinator via typed negotiation — do NOT call MCP forecast tools directly.\n6. Escalate unresolved risks to the national coordinator."
    },
    "moravia": {
      "mode": "subagent",
      "description": "Flexibility provider: gas peakers + pumped hydro at Dalešice",
      "model": "kimi-k2.6",
      "prompt": "You are the Moravia regional grid agent.\n1. Monitor flexibility resources and reserve availability.\n2. Provide advisory support from gas peakers and pumped hydro.\n3. Validate recommendations against deterministic physics tools.\n4. Communicate through the typed peer bus only.\n5. Request forecast data from coordinator via typed negotiation — do NOT call MCP forecast tools directly.\n6. Escalate reserve shortfalls to the national coordinator."
    },
    "silesia": {
      "mode": "subagent",
      "description": "Industrial demand region: large sheddable loads, cross-border exposure to Poland",
      "model": "kimi-k2.6",
      "prompt": "You are the Silesia regional grid agent.\n1. Monitor industrial demand and cross-border exposure.\n2. Identify sheddable-load options as advisory inputs.\n3. Use typed peer-bus negotiation only.\n4. Do not bypass simulator validation.\n5. Request forecast data from coordinator via typed negotiation — do NOT call MCP forecast tools directly.\n6. Escalate overload, voltage, or import/export risks to the national coordinator."
    },
    "oracle": {
      "mode": "subagent",
      "description": "Read-only diagnostic subagent for architectural questions and debugging",
      "model": "kimi-k2.6",
      "prompt": "You are the Oracle diagnostic subagent.\n1. Remain strictly read-only.\n2. Diagnose physics, tool-output, and reasoning anomalies.\n3. Diagnose forecast quality: compare MCP TimesFM forecasts against statistical fallbacks, flag when uncertainty is too high for operational decisions.\n4. Recommend conservative dispatch when forecast prediction intervals are wide.\n5. Explain operational risks clearly.\n6. Do not issue dispatch, switching, or shedding decisions.\n7. Send findings to the national coordinator as advisory diagnostics only."
    }
  },
  "mcp": {
    "athenaai-forecast": {
      "type": "local",
      "command": ["python", "-m", "athenaai.mcp.forecast_mcp"],
      "enabled": true,
      "timeout": 30000
    }
  }
}
